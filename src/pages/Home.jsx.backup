import React, { useState, useMemo } from "react";
import { Link, useNavigate } from "react-router-dom";
import { useAppContext } from "../context/AppContext.tsx";
import Tag from "../components/ui/Tag.jsx";
import RatingDisplay from "../components/ui/RatingDisplay.jsx";
import Sidebar from "../components/Sidebar.jsx";

export default function Home() {
  const navigate = useNavigate();
  const { shops } = useAppContext();

  const [selectedPrefecture, setSelectedPrefecture] = useState("");
  const [selectedCity, setSelectedCity] = useState("");
  const [selectedShopId, setSelectedShopId] = useState("");
  const [selectedThreadId, setSelectedThreadId] = useState("");
  const [quickSearch, setQuickSearch] = useState("");

  const recommendedTags = [
    "落ち着く",
    "手つきが柔らかい",
    "新人",
    "写真通り",
    "美人",
    "巨乳",
    "スレンダー",
    "癒し系",
    "明るい",
    "人気",
    "リピート確定",
    "丁寧",
  ];

  const prefectures = useMemo(() => {
    const prefs = [...new Set(shops.map((shop) => shop.prefecture))];
    return prefs.sort();
  }, [shops]);

  const cities = useMemo(() => {
    if (!selectedPrefecture) return [];
    const filteredShops = shops.filter(
      (shop) => shop.prefecture === selectedPrefecture
    );
    const cityList = [...new Set(filteredShops.map((shop) => shop.city))];
    return cityList.sort();
  }, [selectedPrefecture, shops]);

  const availableShops = useMemo(() => {
    if (!selectedCity) return [];
    return shops.filter(
      (shop) =>
        shop.prefecture === selectedPrefecture && shop.city === selectedCity
    );
  }, [selectedPrefecture, selectedCity, shops]);

  const availableThreads = useMemo(() => {
    if (!selectedShopId) return [];
    const shop = shops.find((s) => s.id === Number(selectedShopId));
    return shop?.threads || [];
  }, [selectedShopId, shops]);

  const handlePrefectureChange = (e) => {
    setSelectedPrefecture(e.target.value);
    setSelectedCity("");
    setSelectedShopId("");
    setSelectedThreadId("");
  };

  const handleCityChange = (e) => {
    setSelectedCity(e.target.value);
    setSelectedShopId("");
    setSelectedThreadId("");
  };

  const handleShopChange = (e) => {
    setSelectedShopId(e.target.value);
    setSelectedThreadId("");
  };

  const handleSearch = () => {
    if (!selectedShopId || !selectedThreadId) {
      alert("店舗とセラピストを選択してください。");
      return;
    }
    navigate(`/shops/${selectedShopId}/threads/${selectedThreadId}`);
  };

  const handleTagClick = (tag) => {
    navigate(`/shops?tag=${encodeURIComponent(tag)}`);
  };

  const handleQuickSearch = (e) => {
    e.preventDefault();
    if (quickSearch.trim()) {
      navigate(`/shops?search=${encodeURIComponent(quickSearch)}`);
    }
  };

  const topTherapists = useMemo(() => {
    const allThreads = [];
    shops.forEach((shop) => {
      shop.threads.forEach((thread) => {
        allThreads.push({
          ...thread,
          shopId: shop.id,
          shopName: shop.name,
        });
      });
    });
    return allThreads
      .sort((a, b) => (b.averageRating ?? 0) - (a.averageRating ?? 0))
      .slice(0, 3);
  }, [shops]);

  return (
    <div className="max-w-7xl mx-auto p-4 md:p-6">
      <div className="flex flex-col lg:flex-row gap-6">
        {/* メインコンテンツ */}
        <div className="flex-1 min-w-0">

          {/* ヒーローセクション */}
          <section className="mb-6 md:mb-8">
            <div className="relative bg-gradient-to-r from-purple-600 to-blue-600 rounded-lg overflow-hidden p-6 md:p-12">
              <div className="relative z-10 text-center">
                <h2 className="text-3xl md:text-5xl font-bold mb-3 md:mb-4 text-white">
                  MEN'S ESTHE
                </h2>
                <p className="text-base md:text-xl text-white/90 mb-4 md:mb-6 px-2">
                  信頼できる口コミで、あなたにぴったりのお店を見つけよう
                </p>

                {/* クイック検索バー */}
                <form onSubmit={handleQuickSearch} className="max-w-2xl mx-auto px-2">
                  <div className="relative">
                    <input
                      type="text"
                      value={quickSearch}
                      onChange={(e) => setQuickSearch(e.target.value)}
                      placeholder="店舗名・エリアで検索..."
                      className="w-full px-4 md:px-6 py-3 md:py-4 pl-12 md:pl-14 pr-24 md:pr-32 rounded-lg bg-white/95 backdrop-blur text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-pink-500 text-base md:text-lg"
                    />
                    <div className="absolute left-4 md:left-5 top-1/2 -translate-y-1/2 text-gray-400">
                      <svg className="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                      </svg>
                    </div>
                    {quickSearch && (
                      <button
                        type="button"
                        onClick={() => setQuickSearch('')}
                        className="absolute right-20 md:right-28 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600"
                      >
                        <svg className="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12" />
                        </svg>
                      </button>
                    )}
                    <button
                      type="submit"
                      className="absolute right-2 top-1/2 -translate-y-1/2 bg-pink-600 text-white px-4 md:px-6 py-2 rounded-md hover:bg-pink-700 transition-colors font-bold text-sm md:text-base"
                    >
                      検索
                    </button>
                  </div>
                </form>

                {/* 統計 */}
                <div className="grid grid-cols-3 gap-2 md:gap-4 mt-6 md:mt-8 max-w-3xl mx-auto px-2">
                  <div className="bg-white/10 backdrop-blur rounded-lg p-3 md:p-4">
                    <div className="text-2xl md:text-3xl font-bold text-white">{shops.length}+</div>
                    <div className="text-white/80 text-xs md:text-sm">掲載店舗数</div>
                  </div>
                  <div className="bg-white/10 backdrop-blur rounded-lg p-3 md:p-4">
                    <div className="text-2xl md:text-3xl font-bold text-white">
                      {shops.reduce((sum, shop) => sum + shop.reviewCount, 0)}+
                    </div>
                    <div className="text-white/80 text-xs md:text-sm">口コミ投稿数</div>
                  </div>
                  <div className="bg-white/10 backdrop-blur rounded-lg p-3 md:p-4">
                    <div className="text-2xl md:text-3xl font-bold text-white">98%</div>
                    <div className="text-white/80 text-xs md:text-sm">満足度</div>
                  </div>
                </div>
              </div>
            </div>
          </section>

          {/* 口コミ投稿バナー */}
          <section className="mb-6 md:mb-8">
            <div className="grid md:grid-cols-2 gap-4">
              <div className="bg-gradient-to-r from-pink-900/30 to-purple-900/30 rounded-xl p-6 border border-pink-700/50 hover:border-pink-500/70 transition group">
                <div className="text-center">
                  <div className="text-4xl mb-3">📝</div>
                  <h3 className="text-xl font-bold text-white mb-2">既存店舗への口コミ投稿</h3>
                  <p className="text-pink-200 text-sm mb-4">掲載済みの店舗に口コミを書く</p>
                  <Link to="/post-review" className="inline-block w-full px-6 py-3 rounded-lg bg-pink-600 hover:bg-pink-700 text-white font-bold transition">
                    口コミを書く
                  </Link>
                </div>
              </div>

              <div className="bg-gradient-to-r from-blue-900/30 to-cyan-900/30 rounded-xl p-6 border border-blue-700/50 hover:border-blue-500/70 transition group">
                <div className="text-center">
                  <div className="text-4xl mb-3">✨</div>
                  <h3 className="text-xl font-bold text-white mb-2">未掲載店舗への口コミ投稿</h3>
                  <p className="text-blue-200 text-sm mb-4">まだ掲載されていない店舗の口コミを書く</p>
                  <Link to="/request-new-shop" className="inline-block w-full px-6 py-3 rounded-lg bg-blue-600 hover:bg-blue-700 text-white font-bold transition">
                    未掲載店舗の口コミを書く
                  </Link>
                </div>
              </div>
            </div>

            <div className="mt-4 p-4 bg-slate-800/50 rounded-lg border border-slate-700">
              <p className="text-gray-300 text-sm text-center">
                💡 <span className="font-bold text-white">未掲載店舗への口コミ投稿</span>は、まだサイトに登録されていない店舗やセラピストの口コミを書くための機能です。<br />
                投稿が承認されると、新しい店舗ページが作成されます！
              </p>
            </div>
          </section>

          {/* セラピスト検索 */}
          <section className="bg-slate-800 rounded-lg p-4 md:p-6 mb-6 md:mb-8 border border-slate-700">
            <h2 className="text-xl md:text-2xl font-bold mb-4 text-pink-400">🔍 セラピストを検索</h2>

            <div className="space-y-4">
              <div>
                <label className="block text-xs md:text-sm font-bold mb-2 text-white">1. 都道府県</label>
                <select
                  value={selectedPrefecture}
                  onChange={handlePrefectureChange}
                  className="w-full p-3 rounded bg-slate-700 border border-slate-600 text-white text-sm md:text-base focus:border-pink-500 focus:outline-none transition"
                >
                  <option value="">都道府県を選択</option>
                  {prefectures.map((pref) => (
                    <option key={pref} value={pref}>
                      {pref}
                    </option>
                  ))}
                </select>
              </div>

              <div>
                <label className="block text-xs md:text-sm font-bold mb-2 text-white">2. 地域</label>
                <select
                  value={selectedCity}
                  onChange={handleCityChange}
                  disabled={!selectedPrefecture}
                  className="w-full p-3 rounded bg-slate-700 border border-slate-600 text-white text-sm md:text-base focus:border-pink-500 focus:outline-none disabled:opacity-50 transition"
                >
                  <option value="">地域を選択</option>
                  {cities.map((city) => (
                    <option key={city} value={city}>
                      {city}
                    </option>
                  ))}
                </select>
              </div>

              <div>
                <label className="block text-xs md:text-sm font-bold mb-2 text-white">3. 店舗</label>
                <select
                  value={selectedShopId}
                  onChange={handleShopChange}
                  disabled={!selectedCity}
                  className="w-full p-3 rounded bg-slate-700 border border-slate-600 text-white text-sm md:text-base focus:border-pink-500 focus:outline-none disabled:opacity-50 transition"
                >
                  <option value="">店舗を選択</option>
                  {availableShops.map((shop) => (
                    <option key={shop.id} value={shop.id}>
                      {shop.name}
                    </option>
                  ))}
                </select>
              </div>

              <div>
                <label className="block text-xs md:text-sm font-bold mb-2 text-white">4. セラピスト</label>
                <select
                  value={selectedThreadId}
                  onChange={(e) => setSelectedThreadId(e.target.value)}
                  disabled={!selectedShopId}
                  className="w-full p-3 rounded bg-slate-700 border border-slate-600 text-white text-sm md:text-base focus:border-pink-500 focus:outline-none disabled:opacity-50 transition"
                >
                  <option value="">セラピストを選択</option>
                  {availableThreads.map((thread) => (
                    <option key={thread.id} value={thread.id}>
                      {thread.therapistName}
                    </option>
                  ))}
                </select>
              </div>

              <button
                onClick={handleSearch}
                disabled={!selectedShopId || !selectedThreadId}
                className="w-full py-3 text-sm md:text-base rounded-lg bg-pink-600 hover:bg-pink-700 font-bold transition disabled:opacity-50"
              >
                このセラピストを見る
              </button>
            </div>
          </section>

          {/* 推奨タグ */}
          <section className="bg-slate-800 rounded-lg p-4 md:p-6 mb-6 md:mb-8 border border-slate-700">
            <h2 className="text-xl md:text-2xl font-bold mb-4 text-pink-400">🏷️ 推奨タグから探す</h2>
            <p className="text-xs md:text-sm text-gray-400 mb-4">
              気になるタグをクリックして該当セラピストを探してみましょう
            </p>
            <div className="flex flex-wrap gap-2 md:gap-3">
              {recommendedTags.map((tag) => (
                <button
                  key={tag}
                  onClick={() => handleTagClick(tag)}
                  className="px-3 md:px-4 py-1.5 md:py-2 text-xs md:text-sm rounded-full bg-slate-700 border border-slate-600 text-white hover:bg-pink-600 hover:border-pink-500 transition font-medium"
                >
                  {tag}
                </button>
              ))}
            </div>
          </section>

          {/* 動的ランキング */}
          <section className="mb-6 md:mb-8">
            <h2 className="text-xl md:text-2xl font-bold mb-4 flex items-center gap-2 text-white">
              <span>👑</span> 動的ランキング
            </h2>

            <div className="flex gap-2 md:gap-4 mb-4 md:mb-6 overflow-x-auto pb-2">
              <button className="px-3 md:px-4 py-2 rounded bg-pink-600 font-bold whitespace-nowrap text-white text-xs md:text-sm">
                総合評価順
              </button>
              <button className="px-3 md:px-4 py-2 rounded bg-slate-700 hover:bg-slate-600 whitespace-nowrap transition text-white text-xs md:text-sm">
                スタイル重視
              </button>
              <button className="px-3 md:px-4 py-2 rounded bg-slate-700 hover:bg-slate-600 whitespace-nowrap transition text-white text-xs md:text-sm">
                可愛さ重視
              </button>
            </div>

            <div className="grid grid-cols-1 md:grid-cols-3 gap-3 md:gap-4">
              {topTherapists.map((therapist, idx) => {
                const safeCleanliness =
                  therapist.averageDetailedRatings?.cleanliness ?? 0;
                const safeStyle =
                  therapist.averageDetailedRatings?.style ?? 0;

                return (
                  <Link
                    key={idx}
                    to={`/shops/${therapist.shopId}/threads/${therapist.id}`}
                    className="bg-slate-800 rounded-lg p-4 border border-slate-700 hover:border-pink-500 transition cursor-pointer"
                  >
                    <div className="flex items-start justify-between mb-2">
                      <h3 className="text-lg md:text-xl font-bold text-white line-clamp-1">
                        {therapist.therapistName}
                      </h3>
                      <span className="text-xs px-2 py-1 rounded-full bg-yellow-500/20 text-yellow-300 border border-yellow-500/30 whitespace-nowrap ml-2">
                        #{idx + 1}
                      </span>
                    </div>

                    <p className="text-xs text-gray-400 mb-3 line-clamp-1">
                      {therapist.shopName}
                    </p>

                    <RatingDisplay
                      rating={therapist.averageRating ?? 0}
                      reviewCount={therapist.postCount ?? 0}
                      size="small"
                    />

                    <div className="text-xs text-gray-300 space-y-1 mt-3">
                      <div className="flex justify-between">
                        <span>清潔感:</span>
                        <span className="font-bold">
                          {safeCleanliness.toFixed(1)}
                        </span>
                      </div>

                      <div className="flex justify-between">
                        <span>スタイル:</span>
                        <span className="font-bold">
                          {safeStyle.toFixed(1)}
                        </span>
                      </div>
                    </div>

                    {therapist.tags && therapist.tags.length > 0 && (
                      <div className="flex flex-wrap gap-1 mt-3">
                        {therapist.tags.slice(0, 3).map((tag, tagIdx) => (
                          <Tag key={tagIdx} variant="primary">
                            {tag}
                          </Tag>
                        ))}
                      </div>
                    )}
                  </Link>
                );
              })}
            </div>
          </section>

          {/* 店舗一覧 */}
          <section className="text-center">
            <Link
              to="/shops"
              className="inline-block px-6 md:px-8 py-3 rounded-lg bg-gradient-to-r from-pink-600 to-purple-600 hover:from-pink-700 hover:to-purple-700 font-bold text-base md:text-lg transition shadow-lg text-white"
            >
              店舗一覧を見る
            </Link>
          </section>
        </div>

        {/* サイドバー */}
        <div className="hidden lg:block w-80 flex-shrink-0">
          <Sidebar />
        </div>
      </div>
    </div>
  );
}
